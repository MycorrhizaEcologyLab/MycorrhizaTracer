    given-names: "Tom"
    affiliation: "Royal Botanic Gardens, Kew"
repository-code: "https://github.com/tom-brekke/MycorrhizaTracer"
url: "https://github.com/tom-brekke/MycorrhizaTracer"
license: MIT
version: "2.3.0"
date-released: "2026-01-28"
keywords:
  - bioinformatics
  - sanger-sequencing
  - mycorrhiza
  - taxonomy
  - ITS
  - fungi
  - OTU-clustering
  - BLAST
  - Python
